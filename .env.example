EBAY_CLIENT_SECRET=
# Legacy aliases (optional): EBAY_APP_ID, EBAY_CERT_ID
EBAY_APP_ID=
EBAY_CERT_ID=
EBAY_SANDBOX=false

# --- Database & Auth ---
DATABASE_URL=
