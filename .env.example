# =============================================================================
# Kauf26 — environment variables
# Copy to `.env` and fill in values. Marketplace blocks are alphabetical by ID.
# =============================================================================

# --- Database & Auth ---
DATABASE_URL=
SESSION_SECRET=
# 32-byte AES key (64-char hex or base64) — encrypts marketplace OAuth tokens at rest
SESSION_ENCRYPTION_KEY=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
APP_BASE_URL=http://localhost:2626
# Web app origin for OAuth success redirects (Vite dev server)
CLIENT_URL=http://localhost:5173
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
UNIFIED_API_KEY=
# Headless browser marketplace login during onboarding (set false to watch browser)
BROWSER_AUTH_HEADLESS=true

# --- AI & Scrapers ---
OPENAI_API_KEY=
APIFY_API_KEY=
# Default: apify/google-search-scraper (organic results + prices). Optional e-commerce actor:
# APIFY_ACTOR_ID=apify/e-commerce-scraping-tool
APIFY_RUN_TIMEOUT_SECS=35
# Parallel scraper race (Stage 2): Apify per-source cap + total race window
APIFY_SCRAPER_TIMEOUT_MS=40000
SCRAPER_RACE_PER_SOURCE_TIMEOUT_MS=40000
SCRAPER_RACE_WINDOW_MS=45000
SCRAPER_RACE_TIMEOUT_MS=45000
SCRAPE_BUDGET_MS=50000
# Google Lens image search (prodiger/google-lens-scraper, products mode)
# APIFY_GOOGLE_LENS_ACTOR_ID=prodiger/google-lens-scraper
GOOGLE_LENS_TIMEOUT_SECS=45
GOOGLE_API_KEY=
GOOGLE_CX=
OXYLABS_USERNAME=
OXYLABS_PASSWORD=
RAPIDAPI_KEY=

# --- Identify queue (in-memory, per server process) ---
IDENTIFY_QUEUE_CONCURRENCY=3
IDENTIFY_JOB_TIMEOUT_MS=60000
IDENTIFY_REQUEST_TIMEOUT_MS=65000
VISION_TIMEOUT_MS=10000

# Verbose identify/scrape merge logging (or use npm run scrape:debug)
IDENTIFY_DEBUG=false

# --- Multi-marketplace publish queue ---
DEFAULT_PUBLISH_MARKETPLACES=ebay,allegro,amazon,etsy,shopify
AUTO_QUEUE_PUBLISH=false
PUBLISH_MAX_ATTEMPTS=3
PUBLISH_RATE_LIMIT_MS=2000

# --- App Settings ---
PORT=2626
VITE_API_URL=

# =============================================================================
# Marketplace credentials (26 approved platforms — alphabetical by ID)
# =============================================================================

# --- aliexpress ---
ALIEXPRESS_APP_KEY=
ALIEXPRESS_APP_SECRET=

# --- allegro ---
ALLEGRO_CLIENT_ID=
ALLEGRO_CLIENT_SECRET=

# --- amazon ---
AMAZON_CLIENT_ID=
AMAZON_CLIENT_SECRET=
AMAZON_REFRESH_TOKEN=
AMAZON_SELLER_ID=
AMAZON_MARKETPLACE_ID=ATVPDKIKX0DER
AMAZON_SANDBOX=false

# --- bigcommerce ---
BIGCOMMERCE_STORE_HASH=
BIGCOMMERCE_ACCESS_TOKEN=

# --- bolcom ---
BOLCOM_CLIENT_ID=
BOLCOM_CLIENT_SECRET=

# --- depop (partnership stub) ---
DEPOP_API_KEY=

# --- ebay (OAuth — server Authorization Code flow) ---
# Register redirect URI in eBay developer portal:
#   http://localhost:2626/api/oauth/ebay/callback  (local)
#   {APP_BASE_URL}/api/oauth/ebay/callback         (production)
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
# Optional mobile deep link (legacy device-only flow)
EBAY_REDIRECT_URI=kauf26://oauth/ebay
EBAY_OAUTH_SCOPES=
# Legacy aliases (optional): EBAY_APP_ID, EBAY_CERT_ID
EBAY_APP_ID=
EBAY_CERT_ID=
EBAY_SANDBOX=false
EBAY_MARKETPLACE_ID=EBAY_US
EBAY_CATEGORY_ID=93427
EBAY_FULFILLMENT_POLICY_ID=
EBAY_PAYMENT_POLICY_ID=
EBAY_RETURN_POLICY_ID=

# --- etsy (OAuth — server Authorization Code flow + PKCE) ---
# ETSY_CLIENT_ID is your Etsy app keystring; it is also the x-api-key header.
# Register redirect URI in Etsy developer portal:
#   http://localhost:2626/api/oauth/etsy/callback
ETSY_CLIENT_ID=
ETSY_CLIENT_SECRET=
# Optional mobile deep link (legacy device-only flow)
ETSY_REDIRECT_URI=kauf26://oauth/etsy
# Optional overrides
ETSY_OAUTH_SCOPES=
ETSY_SHOP_ID=
ETSY_TAXONOMY_ID=1

# --- flipkart ---
FLIPKART_APP_ID=
FLIPKART_APP_SECRET=

# --- fruugo ---
FRUUGO_API_KEY=
FRUUGO_MERCHANT_ID=

# --- lazada ---
LAZADA_APP_KEY=
LAZADA_APP_SECRET=

# --- magento ---
MAGENTO_BASE_URL=https://your-store.com
MAGENTO_ACCESS_TOKEN=

# --- mercadolibre ---
MERCADOLIBRE_CLIENT_ID=
MERCADOLIBRE_CLIENT_SECRET=
MERCADOLIBRE_REFRESH_TOKEN=
MERCADOLIBRE_SITE_ID=MLA
MERCADOLIBRE_CATEGORY_ID=MLA3530
MERCADOLIBRE_CURRENCY=USD

# --- mercadolibre_br ---
# Shares OAuth vars with mercadolibre; Brazil site ID:
MERCADOLIBRE_BR_SITE_ID=MLB

# --- newegg ---
NEWEGG_SELLER_ID=
NEWEGG_API_KEY=

# --- poshmark (partnership stub) ---
POSHMARK_PARTNERSHIP_KEY=

# --- rakuten ---
RAKUTEN_SERVICE_SECRET=
RAKUTEN_LICENSE_KEY=

# --- shopee ---
SHOPEE_PARTNER_ID=
SHOPEE_PARTNER_KEY=
SHOPEE_SHOP_ID=

# --- shopify (OAuth — server Authorization Code flow) ---
# Register redirect URI in Shopify Partners:
#   http://localhost:2626/api/oauth/shopify/callback
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
# Optional mobile deep link (legacy device-only flow)
SHOPIFY_OAUTH_REDIRECT_URI=kauf26://oauth/shopify
SHOPIFY_OAUTH_SCOPES=read_products,write_products
SHOPIFY_APP_BASE_URL=http://localhost:2626

# --- stockx (partnership stub) ---
STOCKX_API_KEY=

# --- taobao ---
TAOBAO_APP_KEY=
TAOBAO_APP_SECRET=

# --- tiktokshop (partnership stub) ---
TIKTOKSHOP_APP_KEY=
TIKTOKSHOP_APP_SECRET=

# --- vinted (partnership stub) ---
VINTED_API_KEY=

# --- wayfair ---
WAYFAIR_CLIENT_ID=
WAYFAIR_CLIENT_SECRET=

# --- woocommerce ---
WOOCOMMERCE_SITE_URL=https://your-site.com
WOOCOMMERCE_CONSUMER_KEY=
WOOCOMMERCE_CONSUMER_SECRET=

# --- zalando ---
ZALANDO_CLIENT_ID=
ZALANDO_CLIENT_SECRET=

# --- Shipping rates & labels (optional — smart mock estimates when unset) ---
# Default ship-from address for label maker
SHIPPING_FROM_NAME=KAUF26 Seller
SHIPPING_FROM_LINE1=123 Warehouse Rd
SHIPPING_FROM_CITY=Los Angeles
SHIPPING_FROM_STATE=CA
SHIPPING_FROM_ZIP=90001
# Unified multi-carrier wrapper (USPS + FedEx + UPS in one key)
EASYPOST_API_KEY=
# Alternative unified wrapper
SHIPPO_API_KEY=
# USPS Web Tools — https://www.usps.com/business/web-tools-apis/
USPS_WEB_TOOLS_USER_ID=
# FedEx Developer — https://developer.fedex.com/
FEDEX_CLIENT_ID=
FEDEX_CLIENT_SECRET=
FEDEX_ACCOUNT_NUMBER=
# Sandbox: https://apis-sandbox.fedex.com | Production: https://apis.fedex.com
FEDEX_API_BASE_URL=https://apis-sandbox.fedex.com
# UPS Developer (optional)
UPS_CLIENT_ID=
UPS_CLIENT_SECRET=
UPS_ACCOUNT_NUMBER=
