# =============================================================================
# Kauf26 — environment variables (safe to commit)
# Copy to `.env` and replace placeholders. Never commit `.env` with real secrets.
# Production skeleton: see `.env.production.example`
# Marketplace detail: `.env.marketplace` | docs/MARKETPLACE_SETUP_CHECKLIST.md
# =============================================================================

# --- Core app ---
PORT=2626
APP_BASE_URL=http://localhost:2626
# Production: https://api.kaufai.com
CLIENT_URL=http://localhost:5173
# Production: https://kaufai.com
VITE_API_URL=http://localhost:2626
# Production build: https://api.kaufai.com
# Local dev: omit or use development. Production server: NODE_ENV=production
# NODE_ENV=development
MOCK_OAUTH_MODE=false
# Set true to simulate OAuth without live marketplace API keys.
# With NODE_ENV=development, also enables Dev Login (PIN 1234) on /login — never use in production.
TRIAL_START_DATE=2026-06-12
BROWSER_AUTH_HEADLESS=true
# Headless browser marketplace login during onboarding (set false to watch browser)

# Production OAuth redirect URIs (register in marketplace / identity provider portals):
#   Marketplace (unified):  https://api.kaufai.com/api/auth/callback
#   Marketplace (legacy):     https://api.kaufai.com/api/oauth/{marketplace}/callback
#   Google Sign-In:           https://api.kaufai.com/api/auth/google/callback
#   Apple Sign-In:            https://api.kaufai.com/api/auth/apple/callback
# Mobile OAuth: kauf26://oauth/{marketplace_id}

# --- Database & session ---
DATABASE_URL=postgresql://localhost:5432/your_database_name_here
SESSION_SECRET=your_session_secret_here
# 32-byte AES key (64-char hex or base64) — encrypts marketplace OAuth tokens at rest
SESSION_ENCRYPTION_KEY=your_64_char_hex_session_encryption_key_here

# --- User sign-in (optional) ---
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
APPLE_CLIENT_ID=your_apple_service_id_here
APPLE_TEAM_ID=your_apple_team_id_here
APPLE_KEY_ID=your_apple_key_id_here
APPLE_PRIVATE_KEY=your_apple_private_key_one_line_here

# --- Billing ---
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here

# --- AI & identify ---
OPENAI_API_KEY=your_openai_api_key_here
UNIFIED_API_KEY=your_unified_api_key_here
# Identify queue (in-memory, per server process)
IDENTIFY_QUEUE_CONCURRENCY=3
IDENTIFY_JOB_TIMEOUT_MS=60000
IDENTIFY_REQUEST_TIMEOUT_MS=65000
VISION_TIMEOUT_MS=10000
# Verbose identify/scrape merge logging (or use npm run scrape:debug)
IDENTIFY_DEBUG=false

# --- Scrapers ---
APIFY_API_KEY=your_apify_api_key_here
# Default: apify/google-search-scraper (organic results + prices). Optional e-commerce actor:
# APIFY_ACTOR_ID=apify/e-commerce-scraping-tool
APIFY_RUN_TIMEOUT_SECS=35
# Parallel scraper race (Stage 2): Apify per-source cap + total race window
APIFY_SCRAPER_TIMEOUT_MS=40000
SCRAPER_RACE_PER_SOURCE_TIMEOUT_MS=40000
SCRAPER_RACE_WINDOW_MS=45000
SCRAPER_RACE_TIMEOUT_MS=45000
SCRAPE_BUDGET_MS=50000
# Google Lens image search (prodiger/google-lens-scraper, products mode)
# APIFY_GOOGLE_LENS_ACTOR_ID=prodiger/google-lens-scraper
GOOGLE_LENS_TIMEOUT_SECS=45
GOOGLE_LENS_TIMEOUT_MS=15000
GOOGLE_SHOPPING_TIMEOUT_MS=3000
APIFY_ACTOR_ID=
APIFY_GOOGLE_LENS_ACTOR_ID=
APIFY_GOOGLE_SEARCH_ACTOR_ID=
PRODUCT_PAGE_FETCH_TIMEOUT_MS=8000
GOOGLE_API_KEY=your_google_cse_api_key_here
GOOGLE_CX=your_google_cse_cx_here
OXYLABS_USERNAME=your_oxylabs_username_here
OXYLABS_PASSWORD=your_oxylabs_password_here
RAPIDAPI_KEY=your_rapidapi_key_here

# --- Translation (optional — Docker: docker compose up -d libretranslate) ---
LIBRETRANSLATE_URL=http://localhost:5000
TRANSLATE_TIMEOUT_MS=15000

# --- Multi-marketplace publish queue ---
DEFAULT_PUBLISH_MARKETPLACES=ebay,allegro,amazon,etsy,shopify
AUTO_QUEUE_PUBLISH=false
PUBLISH_MAX_ATTEMPTS=3
PUBLISH_RATE_LIMIT_MS=2000
INVENTORY_POLL_ENABLED=false
INVENTORY_POLL_INTERVAL_MS=300000

# =============================================================================
# Marketplace credentials (27 platforms — alphabetical by ID)
# Status: live | dry-run | partnership-stub (see server/config/marketplaces.ts)
# OAuth: mobile kauf26://oauth/{id} | web {APP_BASE_URL}/api/auth/callback
# =============================================================================

# --- aliexpress [dry-run] ---
ALIEXPRESS_APP_KEY=your_aliexpress_app_key_here
ALIEXPRESS_APP_SECRET=your_aliexpress_app_secret_here

# --- allegro [live] ---
ALLEGRO_CLIENT_ID=your_allegro_client_id_here
ALLEGRO_CLIENT_SECRET=your_allegro_client_secret_here
ALLEGRO_REDIRECT_URI=

# --- amazon SP-API [dry-run] ---
# Register redirect URI: kauf26://oauth/amazon (mobile) or {APP_BASE_URL}/api/auth/callback (web)
AMAZON_CLIENT_ID=your_amazon_lwa_client_id_here
AMAZON_CLIENT_SECRET=your_amazon_lwa_client_secret_here
AMAZON_REDIRECT_URI=kauf26://oauth/amazon
AMAZON_REFRESH_TOKEN=your_amazon_refresh_token_here
AMAZON_SELLER_ID=your_amazon_seller_id_here
AMAZON_MARKETPLACE_ID=ATVPDKIKX0DER
AMAZON_SANDBOX=false

# --- bigcommerce [dry-run] ---
BIGCOMMERCE_STORE_HASH=your_bigcommerce_store_hash_here
BIGCOMMERCE_ACCESS_TOKEN=your_bigcommerce_access_token_here

# --- bol.com [dry-run] ---
BOLCOM_CLIENT_ID=your_bolcom_client_id_here
BOLCOM_CLIENT_SECRET=your_bolcom_client_secret_here

# --- depop [partnership stub] ---
DEPOP_API_KEY=your_depop_api_key_here

# --- ebay [live, sandbox] https://developer.ebay.com/my/keys ---
# Mobile OAuth redirect (register in eBay Developer Portal): kauf26://oauth/ebay
# Web OAuth redirect / RuName: {APP_BASE_URL}/api/auth/callback
EBAY_CLIENT_ID=your_ebay_client_id_here
EBAY_CLIENT_SECRET=your_ebay_client_secret_here
EBAY_APP_ID=your_ebay_app_id_here
EBAY_CERT_ID=your_ebay_cert_id_here
EBAY_DEV_ID=your_ebay_dev_id_here
EBAY_REDIRECT_URI=kauf26://oauth/ebay
EBAY_OAUTH_SCOPES=
EBAY_SANDBOX=false
EBAY_MARKETPLACE_ID=EBAY_US
EBAY_CATEGORY_ID=93427
EBAY_FULFILLMENT_POLICY_ID=your_ebay_fulfillment_policy_id_here
EBAY_PAYMENT_POLICY_ID=your_ebay_payment_policy_id_here
EBAY_RETURN_POLICY_ID=your_ebay_return_policy_id_here
EBAY_REFRESH_TOKEN=

# --- etsy [live] (OAuth — server Authorization Code flow + PKCE) ---
# ETSY_CLIENT_ID is your Etsy app keystring; it is also the x-api-key header.
# Register redirect URI in Etsy developer portal:
#   {APP_BASE_URL}/api/auth/callback
ETSY_CLIENT_ID=your_etsy_client_id_here
ETSY_CLIENT_SECRET=your_etsy_client_secret_here
ETSY_REDIRECT_URI=
# Optional overrides
ETSY_OAUTH_SCOPES=
ETSY_SHOP_ID=your_etsy_shop_id_here
ETSY_TAXONOMY_ID=1

# --- flipkart [dry-run] ---
FLIPKART_APP_ID=your_flipkart_app_id_here
FLIPKART_APP_SECRET=your_flipkart_app_secret_here

# --- fruugo [dry-run] ---
FRUUGO_API_KEY=your_fruugo_api_key_here
FRUUGO_MERCHANT_ID=your_fruugo_merchant_id_here

# --- lazada [dry-run] ---
LAZADA_APP_KEY=your_lazada_app_key_here
LAZADA_APP_SECRET=your_lazada_app_secret_here

# --- magento [dry-run] ---
MAGENTO_BASE_URL=https://your-magento-store.com
MAGENTO_ACCESS_TOKEN=your_magento_access_token_here

# --- mercadolibre [dry-run] ---
MERCADOLIBRE_CLIENT_ID=your_mercadolibre_client_id_here
MERCADOLIBRE_CLIENT_SECRET=your_mercadolibre_client_secret_here
MERCADOLIBRE_REFRESH_TOKEN=your_mercadolibre_refresh_token_here
MERCADOLIBRE_SITE_ID=MLA
MERCADOLIBRE_CATEGORY_ID=MLA3530
MERCADOLIBRE_CURRENCY=USD

# --- mercadolibre_br (Mercado Livre Brazil) — shares OAuth keys above ---
MERCADOLIBRE_BR_SITE_ID=MLB

# --- newegg [dry-run] ---
NEWEGG_SELLER_ID=your_newegg_seller_id_here
NEWEGG_API_KEY=your_newegg_api_key_here

# --- poshmark [partnership stub] ---
POSHMARK_PARTNERSHIP_KEY=your_poshmark_partnership_key_here

# --- rakuten [dry-run] ---
RAKUTEN_SERVICE_SECRET=your_rakuten_service_secret_here
RAKUTEN_LICENSE_KEY=your_rakuten_license_key_here

# --- shopee [dry-run] ---
SHOPEE_PARTNER_ID=your_shopee_partner_id_here
SHOPEE_PARTNER_KEY=your_shopee_partner_key_here
SHOPEE_SHOP_ID=your_shopee_shop_id_here

# --- shopify [live] (OAuth — server Authorization Code flow) ---
# Register redirect URI in Shopify Partners:
#   {APP_BASE_URL}/api/auth/callback
SHOPIFY_CLIENT_ID=your_shopify_client_id_here
SHOPIFY_CLIENT_SECRET=your_shopify_client_secret_here
SHOPIFY_STORE_NAME=your_store_name_here
SHOPIFY_SHOP_DOMAIN=your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=your_shopify_access_token_here
SHOPIFY_OAUTH_REDIRECT_URI=http://localhost:2626/api/auth/callback
SHOPIFY_OAUTH_SCOPES=read_products,write_products
SHOPIFY_APP_BASE_URL=http://localhost:2626

# --- stockx [partnership stub] ---
STOCKX_API_KEY=your_stockx_api_key_here

# --- taobao [dry-run] ---
TAOBAO_APP_KEY=your_taobao_app_key_here
TAOBAO_APP_SECRET=your_taobao_app_secret_here

# --- tiktok shop [partnership stub] ---
TIKTOKSHOP_APP_KEY=your_tiktokshop_app_key_here
TIKTOKSHOP_APP_SECRET=your_tiktokshop_app_secret_here

# --- vinted [partnership stub] ---
VINTED_API_KEY=your_vinted_api_key_here

# --- wayfair [dry-run] ---
WAYFAIR_CLIENT_ID=your_wayfair_client_id_here
WAYFAIR_CLIENT_SECRET=your_wayfair_client_secret_here

# --- woocommerce [dry-run] ---
WOOCOMMERCE_SITE_URL=https://your-woocommerce-site.com
WOOCOMMERCE_CONSUMER_KEY=your_woocommerce_consumer_key_here
WOOCOMMERCE_CONSUMER_SECRET=your_woocommerce_consumer_secret_here

# --- zalando [dry-run] ---
ZALANDO_CLIENT_ID=your_zalando_client_id_here
ZALANDO_CLIENT_SECRET=your_zalando_client_secret_here

# --- Shipping rates & labels (optional — smart mock estimates when unset) ---
# Email labels (optional — logs to console when SMTP_HOST unset)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
# Default ship-from address for label maker
SHIPPING_FROM_NAME=KAUF26 Seller
SHIPPING_FROM_LINE1=123 Warehouse Rd
SHIPPING_FROM_CITY=Los Angeles
SHIPPING_FROM_STATE=CA
SHIPPING_FROM_ZIP=90001
# Unified multi-carrier wrapper (USPS + FedEx + UPS in one key)
EASYPOST_API_KEY=your_easypost_api_key_here
# Alternative unified wrapper
SHIPPO_API_KEY=your_shippo_api_key_here
# USPS Web Tools — https://www.usps.com/business/web-tools-apis/
USPS_WEB_TOOLS_USER_ID=your_usps_web_tools_user_id_here
# FedEx Developer — https://developer.fedex.com/
FEDEX_CLIENT_ID=your_fedex_client_id_here
FEDEX_CLIENT_SECRET=your_fedex_client_secret_here
FEDEX_ACCOUNT_NUMBER=your_fedex_account_number_here
# Sandbox: https://apis-sandbox.fedex.com | Production: https://apis.fedex.com
FEDEX_API_BASE_URL=https://apis-sandbox.fedex.com
# UPS Developer (optional)
UPS_CLIENT_ID=your_ups_client_id_here
UPS_CLIENT_SECRET=your_ups_client_secret_here
UPS_ACCOUNT_NUMBER=your_ups_account_number_here
