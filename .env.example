# --- eBay (Browse API — use Production Client ID + Secret from developer.ebay.com) ---
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
# Legacy aliases (optional): EBAY_APP_ID, EBAY_CERT_ID
EBAY_APP_ID=
EBAY_CERT_ID=
EBAY_SANDBOX=false

# --- Database & Auth ---
DATABASE_URL=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
UNIFIED_API_KEY=

# --- AI & Scrapers ---
OPENAI_API_KEY=
APIFY_API_KEY=
# Default: apify/google-search-scraper (organic results + prices). Optional e-commerce actor:
# APIFY_ACTOR_ID=apify/e-commerce-scraping-tool
APIFY_RUN_TIMEOUT_SECS=35
# Parallel scraper race (Stage 2): Apify per-source cap + total race window
APIFY_SCRAPER_TIMEOUT_MS=40000
SCRAPER_RACE_PER_SOURCE_TIMEOUT_MS=40000
SCRAPER_RACE_WINDOW_MS=45000
SCRAPER_RACE_TIMEOUT_MS=45000
SCRAPE_BUDGET_MS=50000
# Google Lens image search (prodiger/google-lens-scraper, products mode)
# APIFY_GOOGLE_LENS_ACTOR_ID=prodiger/google-lens-scraper
GOOGLE_LENS_TIMEOUT_SECS=45
GOOGLE_API_KEY=
GOOGLE_CX=
OXYLABS_USERNAME=
OXYLABS_PASSWORD=
RAPIDAPI_KEY=

# --- Identify queue (in-memory, per server process) ---
IDENTIFY_QUEUE_CONCURRENCY=3
IDENTIFY_JOB_TIMEOUT_MS=60000
IDENTIFY_REQUEST_TIMEOUT_MS=65000
VISION_TIMEOUT_MS=10000

# Verbose identify/scrape merge logging (or use npm run scrape:debug)
IDENTIFY_DEBUG=false

# --- Multi-marketplace publish queue ---
DEFAULT_PUBLISH_MARKETPLACES=ebay,allegro,amazon,etsy,shopify
AUTO_QUEUE_PUBLISH=false
PUBLISH_MAX_ATTEMPTS=3
PUBLISH_RATE_LIMIT_MS=2000

