  "license": "MIT",
  "type": "module",
  "private": true,
  "workspaces": [
    "mobile",
    "shared"
  ],
  "scripts": {
    "dev": "vite",
    "server": "tsx watch server/index.ts",
    "dev:all": "concurrently -n server,mobile,web -c blue,magenta,green \"npm run server\" \"npm run mobile:start\" \"npm run dev\"",
    "mobile:start": "npm run start --workspace=global-marketplace-lister",
    "mobile:ios": "npm run ios --workspace=global-marketplace-lister",
    "mobile:android": "npm run android --workspace=global-marketplace-lister",
    "build": "tsc && vite build",
    "start": "node dist/index.js",
    "db:push": "drizzle-kit push",
    "db:migrate": "drizzle-kit migrate",
    "lint": "eslint .",
    "test": "vitest",
    "preview": "vite preview",
    "publish:draft": "tsx scripts/publish-draft.ts",
    "scrape:debug": "tsx scripts/scrape-debug.ts",
    "kauft": "tsx scripts/kauft.ts",
    "test:publish": "vitest run server/services/publishEngine.test.ts",
    "test:adapters": "tsx scripts/test-adapters.ts",
    "test:shopify": "tsx scripts/shopify-test-products.ts",
    "verify:store-readiness": "node scripts/verify-store-readiness.js",
    "validate:production-env": "bash scripts/validate-production-env.sh",
    "deploy:production": "bash scripts/deploy-production.sh"
  },
  "bin": {
    "kauft": "./scripts/kauft.ts"
  },

