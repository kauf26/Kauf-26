# Mobile build-time env (Expo). Copy to `.env` in this folder.
# Redirect URI setup: ../docs/mobile-oauth-redirect-setup.md
#
# OAuth authorize/token URLs are defined in shared/marketplaceOAuthManifest.ts
# (eBay, Amazon, Etsy, Shopify, etc. — no placeholder example.com URLs).
# Client IDs are served by GET /api/marketplaces/oauth-config from the server .env.

# REQUIRED — backend API base URL (no trailing slash).
# Local dev (simulator):       http://localhost:2626
# Local dev (physical device): http://YOUR_LAN_IP:2626
# Production:                  https://api.yourdomain.com
EXPO_PUBLIC_API_URL=

# REQUIRED for production EAS builds — web app origin for Privacy Policy & Terms links.
# Example: https://yourdomain.com  →  /privacy and /terms in Settings
EXPO_PUBLIC_WEB_BASE_URL=
# Optional overrides (use instead of WEB_BASE_URL + path):
# EXPO_PUBLIC_PRIVACY_URL=https://yourdomain.com/privacy
# EXPO_PUBLIC_TERMS_URL=https://yourdomain.com/terms

# OAuth client secrets belong in the SERVER .env only (never in the mobile bundle).
# After OAuth redirect, the app sends the authorization code to:
#   POST /api/auth/:marketplace/exchange
# See ../docs/mobile-oauth-redirect-setup.md
