# Mobile build-time env (Expo). Copy to .env in this folder for local dev builds.
# Redirect URI setup: ../docs/mobile-oauth-redirect-setup.md
# Server OAuth client IDs come from GET /api/marketplaces/oauth-config — do not put tokens here.

# Required for Shopify/eBay on-device token exchange (Etsy uses PKCE only)
EXPO_PUBLIC_SHOPIFY_CLIENT_SECRET=
EXPO_PUBLIC_EBAY_CLIENT_SECRET=

# Optional: override API base (defaults to dev machine / production URL in api.ts)
# EXPO_PUBLIC_API_URL=http://localhost:2626
