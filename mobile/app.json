{
  "expo": {
    "name": "global-marketplace-lister",
    "slug": "global-marketplace-lister",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.globalmarketplacelister.app",
      "buildNumber": "1",
      "usesAppleSignIn": true,
      "infoPlist": {
        "CFBundleDisplayName": "Kauf26",
        "NSAppTransportSecurity": {
          "NSAllowsLocalNetworking": true
        },
        "NSCameraUsageDescription": "Kauf26 uses your camera to scan product photos for AI-powered listing generation.",
        "NSPhotoLibraryUsageDescription": "Kauf26 accesses your photo library to select product images for AI identification and listing creation.",
        "NSPhotoLibraryAddUsageDescription": "Kauf26 saves generated product images to your photo library.",
        "NSFaceIDUsageDescription": "Use Face ID to quickly unlock the app instead of entering your PIN.",
        "LSApplicationCategoryType": "public.app-category.business",
        "CFBundleURLTypes": [
          {
            "CFBundleURLName": "kauf26.oauth",
            "CFBundleURLSchemes": ["kauf26"]
          },
          {
            "CFBundleURLName": "kauf26.auth",
            "CFBundleURLSchemes": ["kauf26"]
          }
        ]
      },
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.globalmarketplacelister.app",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": false,
          "data": [
            {
              "scheme": "kauf26",
              "host": "oauth",
              "pathPrefix": "/"
            },
            {
              "scheme": "kauf26",
              "host": "auth",
              "pathPrefix": "/"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "scheme": "kauf26",
    "plugins": [
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "15.1"
          }
        }
      ],
      "expo-dev-client",
      [
        "expo-camera",
        {
          "cameraPermission": "Kauf26 uses your camera to scan product photos for AI-powered listing generation.",
          "photosPermission": "Kauf26 accesses your photo library to select product images for AI identification and listing creation.",
          "microphonePermission": false,
          "recordAudioAndroid": false
        }
      ],
      "expo-image-picker",
      "expo-secure-store",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Use Face ID to quickly unlock the app instead of entering your PIN."
        }
      ],
      "expo-apple-authentication",
      "expo-font",
      "expo-asset"
    ]
  }
}
