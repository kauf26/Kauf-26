{
  "expo": {
    "name": "global-marketplace-lister",
    "slug": "global-marketplace-lister",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.globalmarketplacelister.app",
      "buildNumber": "1.0.0",
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Take photos of products to create marketplace listings with AI-powered descriptions.",
        "NSPhotoLibraryUsageDescription": "Select product photos from your library to list on multiple marketplaces.",
        "NSFaceIDUsageDescription": "Use Face ID to quickly unlock the app instead of entering your PIN.",
        "CFBundleURLTypes": [
          {
            "CFBundleURLName": "kauf26.oauth",
            "CFBundleURLSchemes": ["kauf26"]
          },
          {
            "CFBundleURLName": "kauf26.auth",
            "CFBundleURLSchemes": ["kauf26"]
          }
        ]
      },
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.globalmarketplacelister.app",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": false,
          "data": [
            {
              "scheme": "kauf26",
              "host": "oauth",
              "pathPrefix": "/"
            },
            {
              "scheme": "kauf26",
              "host": "auth",
              "pathPrefix": "/"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "scheme": "kauf26",
    "plugins": [
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "15.1"
          }
        }
      ],
      "expo-dev-client",
      [
        "expo-camera",
        {
          "cameraPermission": "Take photos of products to create marketplace listings with AI-powered descriptions.",
          "microphonePermission": false,
          "recordAudioAndroid": false
        }
      ],
      "expo-image-picker",
      "expo-secure-store",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Use Face ID to quickly unlock the app instead of entering your PIN."
        }
      ],
      "expo-apple-authentication",
      "expo-font",
      "expo-asset"
    ]
  }
}
