{
  "name": "global-marketplace-lister",
  "version": "1.0.0",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "validate:production-env": "node scripts/validate-production-env.js --production",
    "build:ios": "npm run validate:production-env && eas build --platform ios --profile production",
    "build:android": "npm run validate:production-env && eas build --platform android --profile production"
  },
  "dependencies": {
    "@expo/vector-icons": "^14.0.0",
    "@react-navigation/bottom-tabs": "^6.5.0",
    "@react-navigation/native": "^6.1.0",
    "expo": "~51.0.0",
    "expo-auth-session": "~5.5.2",
    "expo-camera": "~15.0.0",
    "expo-crypto": "~13.0.2",
    "expo-image-picker": "~15.1.0",
    "expo-secure-store": "~13.0.0",
    "expo-status-bar": "~1.12.0",
    "expo-web-browser": "~13.0.3",
    "react": "18.2.0",
    "react-native": "0.74.5",
    "react-native-gesture-handler": "~2.16.0",
    "react-native-safe-area-context": "4.10.5",
    "react-native-screens": "~3.31.0"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@types/react": "~18.2.0",
    "typescript": "~5.3.3"
  },
  "private": true
}
