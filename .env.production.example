# =============================================================================
# Kauf26 — production server .env (copy to `.env` on the deployment host)
# Full variable list: see `.env.example`
# =============================================================================

NODE_ENV=production
PORT=2626

# --- Core (required) ---
DATABASE_URL=postgresql://user:pass@localhost:5432/kauf26
SESSION_SECRET=
# 32-byte key — e.g. openssl rand -hex 32
SESSION_ENCRYPTION_KEY=

APP_BASE_URL=https://api.kaufai.com
CLIENT_URL=https://kaufai.com
VITE_API_URL=https://api.kaufai.com

# --- User sign-in (required if using Google / Apple login) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# --- AI (required for identify / listing copy) ---
OPENAI_API_KEY=

# --- Marketplace OAuth (set keys for marketplaces you support) ---
# Register https://api.kaufai.com/api/auth/callback in each developer portal.
ETSY_CLIENT_ID=
ETSY_CLIENT_SECRET=
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
AMAZON_CLIENT_ID=
AMAZON_CLIENT_SECRET=
AMAZON_SELLER_ID=

# Never enable in production
MOCK_OAUTH_MODE=false

# --- Optional ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
TRIAL_START_DATE=2026-06-12

# Shipping, scrapers, remaining 26 marketplace blocks → see `.env.example`
