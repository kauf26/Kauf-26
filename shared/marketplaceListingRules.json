    "etsy": {
      "policyHint": "Etsy requires handmade, vintage (20+ years), or craft supplies — not mass-produced or new electronics.",
      "blockedKeywords": [
        "mass produced",
        "mass-produced",
        "factory made",
        "dropship",
        "dropshipping",
        "aliexpress",
        "counterfeit",
        "replica"
      ],
      "conditionalRules": [
        {
          "id": "etsy-electronics-non-vintage",
          "matchKeywords": [
            "electronics",
            "laptop",
            "phone",
            "iphone",
            "ipad",
            "tablet",
            "smartphone",
            "macbook",
            "television",
            "tv"
          ],
          "allowKeywords": ["vintage", "antique", "retro"],
          "message": "Etsy: new electronics are not allowed (vintage items may qualify)"
        },
        {
          "id": "etsy-mass-produced-clothing",
          "matchKeywords": ["new with tags", "nwt", "brand new", "fast fashion"],
          "allowKeywords": ["handmade", "hand made", "vintage", "antique", "custom", "supplies"],
          "message": "Etsy: mass-produced new items are not allowed — list as handmade, vintage, or supplies"
        }
      ]
    },
    "wayfair": {
      "policyHint": "Wayfair accepts home and furniture items only.",
      "allowedKeywords": [
        "home",
        "furniture",
        "furnishing",
        "decor",
        "kitchen",
        "bedding",
        "rug",
        "lamp",
        "sofa",
        "chair",
        "table"
      ],
      "blockedKeywords": ["watch", "watches", "sneaker", "sneakers", "clothing", "electronics", "jewelry", "handbag"]
